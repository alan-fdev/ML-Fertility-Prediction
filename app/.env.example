# FertilityPro Backend Configuration Template
# Copy this file to .env and update values for your environment

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_APP=app.py

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Application Secret Key
# In production, use a strong random key: 
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=fertility-pro-secret-key-change-in-production

# Model Configuration (relative to app directory)
MODEL_PATH=../model/best_model.pkl
PREPROCESSOR_PATH=../model/preprocessor.pkl
LABEL_ENCODER_PATH=../model/label_encoder.pkl
FEATURE_NAMES_PATH=../model/feature_names.pkl

# Database (optional)
DATABASE_URL=sqlite:///fertility_pro.db
SQLALCHEMY_ECHO=False
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# API Configuration
API_MAX_CONTENT_LENGTH=16777216  # 16MB
JSON_SORT_KEYS=False
JSONIFY_PRETTYPRINT_REGULAR=False

# CORS (Cross-Origin Resource Sharing)
# For development: *
# For production: specific domains
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Security
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_SSL_REDIRECT=False  # Set to True in production with HTTPS

# Cache
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# Rate Limiting
RATELIMIT_ENABLED=False
RATELIMIT_DEFAULT=100/hour

# Email (for future notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Sentry (Error tracking)
SENTRY_DSN=

# Analytics (optional)
GOOGLE_ANALYTICS_ID=

# Timezone
TIMEZONE=Asia/Jakarta

# Environment specific settings
APP_ENV=development
DEBUG_TOOLBAR_ENABLED=True
